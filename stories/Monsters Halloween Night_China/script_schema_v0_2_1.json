  "role_packets": [
    {
      "packet_id": "wolf_intro_private",
      "character_id": "wolf",
      "phase_id": "intro",
      "content": "你是狼。你被孩童误认为布偶服工作人员而遭欺负，后来逃入等候室，因地板上的血滑倒。你找不到补给橱柜的钥匙，于是撬坏橱柜，发现里面的孩童并将其吃掉，又撕碎孩童衣物丢进垃圾桶。必须隐藏自己是犯人、撬坏橱柜、撕碎衣物。",
      "content_ref": null,
      "visibility": "private",
      "recipients": [],
      "after_reveal_visibility": "private",
      "reveal_instruction": "may_share"
    },
    {
