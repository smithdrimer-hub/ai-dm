  "public_materials": {
    "setting": "万圣节活动期间，四个真正的怪物在主题乐园“克苏鲁仙境”打工。闭园后，业主宣称有一名孩童失踪，并要求找出袭击客人的犯人。",
    "public_intro": "四位怪物在乐园的万圣节活动中担任工作人员。活动结束后，业主指控有人袭击了失踪的孩童。在找出犯人之前，所有人的报酬都会被冻结。",
    "rules_text": "犯人以外的人不能说谎；不想透露的事可以说 NO COMMENT 或“我不知道”。讨论中会逐步公开线索，最终所有玩家同时公开自己的答案。",
    "cast_public_list": [
      {
        "character_id": "wolf",
        "display_name": "狼",
        "public_profile": "拥有强大力量的狼人，擅长用庞大的身体进行表演。"
      },
      {
        "character_id": "witch",
        "display_name": "女巫",
        "public_profile": "驼背的魔女，能把真正的魔法伪装成魔术表演。"
      },
      {
        "character_id": "vampire",
        "display_name": "吸血鬼",
        "public_profile": "面色苍白的真祖吸血鬼，举止天然就像吸血鬼。"
      },
      {
        "character_id": "mummy",
        "display_name": "木乃伊",
        "public_profile": "来自埃及的木乃伊，因原本是人类而更擅长服务游客。"
      }
    ],
    "opening_script": "欢迎来到闭园后的克苏鲁仙境。今晚，灯光已经熄灭，但问题还没有结束。请各位怪物先确认自己的角色信息，记住：除犯人外不能说谎；如果被问到不能说的内容，可以选择 NO COMMENT。",
    "player_guidance": "先围绕时间线、进入等候室的顺序、补给橱柜和每个人看到的异常展开讨论。不要朗读角色私密信息，除非规则或 DM 明确要求。",
    "content_notes": "本迁移稿只服务当前固定 demo 剧本；部分内容从既有结构化数据压缩整理，未做 PDF 自动解析。"
  },
