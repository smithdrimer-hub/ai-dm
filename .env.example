# API 提供商选择：ecnu（华东师范大学）或 custom（自定义）
API_PROVIDER=ecnu

# ========== ECNU 配置（默认）==========
# ECNU LLM API Key
OPENAI_API_KEY=your_ecnu_api_key_here

# ECNU API 地址（一般不需要修改）
OPENAI_BASE_URL=https://chat.ecnu.edu.cn/open/api/v1
OPENAI_MODEL=ecnu-max
OPENAI_TIMEOUT_SECONDS=60

# ECNU TTS 配置
ECNU_TTS_MODEL=ecnu-tts
ECNU_DEFAULT_VOICE=xiayu

# ========== 自定义 API 配置（如使用 API_PROVIDER=custom）==========
# CUSTOM_API_KEY=your_custom_api_key
# CUSTOM_BASE_URL=https://your-api-endpoint.com/v1
# CUSTOM_MODEL=your-model-name

# ========== 通用配置 ==========
# TTS 请求超时（秒）
TTS_TIMEOUT_SECONDS=60